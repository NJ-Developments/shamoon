rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAdmin() {
      return request.auth != null
        && request.auth.token.admin == true;
    }

    // Public assets used by the financial-literacy page (article cover images).
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // The lead magnet PDF. Public read so the auto-reply email can link
    // a download URL; only admin can upload/replace it.
    match /lead-magnet/{file} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
